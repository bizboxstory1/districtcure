# ══════════════════════════════════════════════
#  District Cure — Environment Variables
#  Copy this to .env and fill in your values
#  NEVER commit .env to git
# ══════════════════════════════════════════════

# Server
PORT=3000
NODE_ENV=production

# Your live domain (comma-separated if www + naked)
ALLOWED_ORIGINS=https://districtcure.com,https://www.districtcure.com

# ── Dutchie Integration ──────────────────────
# Your dispensary slug (already set correctly)
DUTCHIE_SLUG=district-smoke-shop

# Your Dutchie API key — leave blank for now,
# the store will use your verified fallback menu.
# Get from: backoffice.dutchie.com → Settings → API
DUTCHIE_API_KEY=

# ── Admin Panel Security ─────────────────────
# Change this to a long random string
# Generate one: openssl rand -hex 32
ADMIN_KEY=change_this_to_a_long_random_string

# ── Optional: SMS notifications (Twilio) ────
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ── Optional: Email (SendGrid) ───────────────
SENDGRID_KEY=
EMAIL_FROM=hello@districtcure.com
